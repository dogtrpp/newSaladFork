	{% endif %}
	{% if 'Y' in params %}
	{% set home_y = True %}
	{% endif %}
	{% if 'Z' in params %}
	{% set home_z = True %}
	{% endif %}
	{% if 'X' in params
	and 'Y' in params
	and 'Z' in params %}
	_Homing_Variables reset=1
	{% endif %}
